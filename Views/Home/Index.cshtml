@{
    ViewData["Title"] = "Group Posts Crawler";
}

<style>
    :root {
        --bg-primary: #0a0a0f;
        --bg-secondary: #12121a;
        --bg-card: #1a1a2e;
        --bg-input: #16162a;
        --border: #2a2a4a;
        --text-primary: #e8e8f0;
        --text-secondary: #8888aa;
        --accent: #6c5ce7;
        --accent-hover: #7c6cf7;
        --accent-glow: rgba(108, 92, 231, 0.3);
        --success: #00d2d3;
        --danger: #ff6b6b;
        --warning: #feca57;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        background: var(--bg-primary);
        color: var(--text-primary);
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        min-height: 100vh;
    }

    .container-main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    .header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        background: linear-gradient(135deg, #6c5ce7, #00d2d3);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
    }

    .header p {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    /* Form Card */
    .form-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .form-row.full {
        grid-template-columns: 1fr;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .form-group label {
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-group input {
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-primary);
        padding: 0.7rem 1rem;
        font-size: 0.95rem;
        transition: border-color 0.2s;
        outline: none;
    }

    .form-group input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-glow);
    }

    .form-group input::placeholder {
        color: #555;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-top: 1rem;
    }

    .btn-crawl {
        background: linear-gradient(135deg, #6c5ce7, #5a4bd1);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.8rem 2rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-crawl:hover {
        background: linear-gradient(135deg, #7c6cf7, #6c5ce7);
        transform: translateY(-1px);
        box-shadow: 0 4px 15px var(--accent-glow);
    }

    .btn-crawl:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-crawl .spinner {
        display: none;
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    .btn-crawl.loading .spinner { display: block; }
    .btn-crawl.loading .btn-text { display: none; }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        font-size: 0.85rem;
    }

    .checkbox-group input[type="checkbox"] {
        accent-color: var(--accent);
        width: 16px;
        height: 16px;
    }

    /* Progress Panel */
    .progress-panel {
        display: none;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .progress-panel.visible { display: block; }

    .progress-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .progress-header .phase-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .progress-header .phase-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--accent);
        animation: pulse 1.5s ease-in-out infinite;
    }

    .progress-header .elapsed-time {
        font-size: 0.85rem;
        color: var(--text-secondary);
        font-variant-numeric: tabular-nums;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    .progress-bar-container {
        background: var(--bg-input);
        border-radius: 10px;
        height: 28px;
        overflow: hidden;
        position: relative;
        margin-bottom: 0.8rem;
        border: 1px solid var(--border);
    }

    .progress-bar-fill {
        height: 100%;
        border-radius: 10px;
        background: linear-gradient(90deg, #6c5ce7, #00d2d3);
        transition: width 0.5s ease;
        min-width: 0;
    }

    .progress-bar-fill.indeterminate {
        width: 100% !important;
        background: linear-gradient(90deg,
            var(--bg-input) 0%,
            #6c5ce7 20%,
            #00d2d3 50%,
            #6c5ce7 80%,
            var(--bg-input) 100%
        );
        background-size: 200% 100%;
        animation: shimmer 2s linear infinite;
    }

    @@keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .progress-bar-text {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 600;
        color: white;
        text-shadow: 0 1px 2px rgba(0,0,0,0.5);
        z-index: 1;
    }

    .progress-details {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.82rem;
        color: var(--text-secondary);
    }

    .progress-steps {
        display: flex;
        gap: 0;
        margin-top: 1.2rem;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
    }

    .step-item {
        flex: 1;
        text-align: center;
        position: relative;
    }

    .step-item::after {
        content: '';
        position: absolute;
        top: 14px;
        right: -50%;
        width: 100%;
        height: 2px;
        background: var(--border);
        z-index: 0;
    }

    .step-item:last-child::after { display: none; }

    .step-item.active::after,
    .step-item.done::after {
        background: var(--accent);
    }

    .step-dot {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--bg-input);
        border: 2px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.4rem;
        font-size: 0.75rem;
        position: relative;
        z-index: 1;
        transition: all 0.3s;
    }

    .step-item.active .step-dot {
        border-color: var(--accent);
        background: var(--accent);
        color: white;
        box-shadow: 0 0 10px var(--accent-glow);
    }

    .step-item.done .step-dot {
        border-color: var(--success);
        background: var(--success);
        color: white;
    }

    .step-label {
        font-size: 0.72rem;
        color: var(--text-secondary);
        transition: color 0.3s;
    }

    .step-item.active .step-label {
        color: var(--accent);
        font-weight: 600;
    }

    .step-item.done .step-label {
        color: var(--success);
    }

    .results-meta .badge-time {
        background: rgba(108, 92, 231, 0.15);
        border-color: rgba(108, 92, 231, 0.3);
    }

    .results-meta .badge-time strong {
        color: var(--accent);
    }

    /* Guide Card */
    .guide-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .guide-card h3 {
        font-size: 1rem;
        color: var(--warning);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .guide-card ol {
        padding-left: 1.5rem;
        color: var(--text-secondary);
        font-size: 0.85rem;
        line-height: 1.8;
    }

    .guide-card code {
        background: var(--bg-input);
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        color: var(--success);
        font-family: 'Consolas', monospace;
        font-size: 0.82rem;
    }

    /* Error */
    .error-card {
        display: none;
        background: rgba(255, 107, 107, 0.1);
        border: 1px solid rgba(255, 107, 107, 0.3);
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        color: var(--danger);
        font-size: 0.9rem;
    }

    .error-card.visible { display: block; }

    /* Results */
    .results-wrapper {
        display: none;
    }

    .results-wrapper.visible { display: block; }

    .results-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .results-header h2 {
        font-size: 1.2rem;
        font-weight: 600;
    }

    .results-meta {
        display: flex;
        gap: 1.5rem;
        color: var(--text-secondary);
        font-size: 0.85rem;
    }

    .results-meta .badge {
        background: var(--bg-input);
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        border: 1px solid var(--border);
    }

    .results-meta .badge strong {
        color: var(--success);
    }

    /* Tabs */
    .tabs {
        display: flex;
        gap: 0;
        border-bottom: 1px solid var(--border);
        margin-bottom: 1rem;
    }

    .tab-btn {
        background: none;
        border: none;
        color: var(--text-secondary);
        padding: 0.7rem 1.5rem;
        font-size: 0.9rem;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        transition: all 0.2s;
    }

    .tab-btn:hover { color: var(--text-primary); }

    .tab-btn.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
    }

    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* Posts Table */
    .posts-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
    }

    .posts-table th {
        background: var(--bg-input);
        color: var(--text-secondary);
        font-weight: 600;
        text-align: left;
        padding: 0.7rem 1rem;
        border-bottom: 1px solid var(--border);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .posts-table td {
        padding: 0.7rem 1rem;
        border-bottom: 1px solid rgba(42, 42, 74, 0.5);
        vertical-align: top;
    }

    .posts-table tr:hover td {
        background: rgba(108, 92, 231, 0.05);
    }

    .posts-table .col-content {
        max-width: 400px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .posts-table .col-content:hover {
        white-space: normal;
        word-break: break-word;
    }

    .posts-table .col-author {
        color: var(--accent);
        font-weight: 500;
        white-space: nowrap;
    }

    .posts-table .col-time {
        color: var(--text-secondary);
        white-space: nowrap;
        font-size: 0.8rem;
    }

    .posts-table .col-stats {
        white-space: nowrap;
        font-size: 0.8rem;
    }

    .stat-badge {
        display: inline-block;
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.75rem;
        margin-right: 0.3rem;
    }

    .stat-reactions { background: rgba(255,107,107,0.15); color: #ff6b6b; }
    .stat-comments { background: rgba(0,210,211,0.15); color: #00d2d3; }
    .stat-shares { background: rgba(254,202,87,0.15); color: #feca57; }

    .post-link {
        color: var(--accent);
        text-decoration: none;
        font-size: 0.8rem;
    }

    .post-link:hover { text-decoration: underline; }

    /* JSON view */
    .json-view {
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem;
        overflow-x: auto;
        max-height: 600px;
        overflow-y: auto;
    }

    .json-view pre {
        color: var(--text-secondary);
        font-family: 'Consolas', monospace;
        font-size: 0.8rem;
        white-space: pre-wrap;
        word-break: break-all;
    }

    /* Export button */
    .btn-export {
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        padding: 0.5rem 1rem;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.8rem;
        transition: all 0.2s;
    }

    .btn-export:hover {
        border-color: var(--accent);
        color: var(--text-primary);
    }
</style>

<div class="container-main">
    <div class="header">
        <h1>⚡ Facebook Group Posts Crawler</h1>
        <p>Crawl bài viết nhóm Facebook qua GraphQL API</p>
    </div>

    <!-- Guide -->
    <div class="guide-card" id="guideCard">
        <h3>📋 Cách hoạt động</h3>
        <ol>
            <li>Nhập <strong>URL nhóm Facebook</strong> bên dưới rồi nhấn "Bắt Đầu Cào"</li>
            <li>Chrome sẽ <strong>tự động mở</strong> — đăng nhập Facebook nếu lần đầu</li>
            <li>Script tự lấy cookies, token, và <code>doc_id</code> từ GraphQL</li>
            <li>Sau khi lấy xong, Chrome đóng → bắt đầu cào bài viết qua HTTP</li>
            <li>Kết quả hiển thị dạng <strong>Bảng</strong> hoặc <strong>JSON</strong>, có thể xuất file</li>
        </ol>
    </div>

    <!-- Form -->
    <div class="form-card">
        <div class="form-row full">
            <div class="form-group">
                <label>Group URL</label>
                <input type="text" id="groupUrl"
                       placeholder="https://www.facebook.com/groups/your-group-id" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Từ ngày</label>
                <input type="datetime-local" id="dateFrom" />
            </div>
            <div class="form-group">
                <label>Đến ngày</label>
                <input type="datetime-local" id="dateTo" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Số bài tối đa</label>
                <input type="number" id="maxPosts" value="100" min="1" max="5000" />
            </div>
            <div class="form-group" style="justify-content: flex-end;">
                <div class="checkbox-group">
                    <input type="checkbox" id="clearCookies" />
                    <label for="clearCookies" style="text-transform:none;font-weight:400;">
                        Xóa cookie (đăng nhập lại)
                    </label>
                </div>
            </div>
        </div>
        <div class="form-actions">
            <button class="btn-crawl" id="btnCrawl" onclick="startCrawl()">
                <div class="spinner"></div>
                <span class="btn-text">🚀 Bắt Đầu Cào</span>
            </button>
        </div>
    </div>

    <!-- Progress Panel -->
    <div class="progress-panel" id="progressPanel">
        <div class="progress-header">
            <div class="phase-label">
                <div class="phase-dot"></div>
                <span id="progressPhaseText">Đang khởi tạo...</span>
            </div>
            <div class="elapsed-time">
                <span>⏱️</span>
                <span id="elapsedTime">00:00</span>
            </div>
        </div>

        <div class="progress-bar-container">
            <div class="progress-bar-fill indeterminate" id="progressBarFill" style="width: 0%"></div>
            <div class="progress-bar-text" id="progressBarText">Đang chuẩn bị...</div>
        </div>

        <div class="progress-details">
            <div>
                <span id="progressMessage">Đang kết nối...</span>
            </div>
            <div style="font-variant-numeric: tabular-nums;">
                <span id="progressStats"></span>
            </div>
        </div>

        <div class="progress-steps">
            <div class="step-item active" id="step-login">
                <div class="step-dot">1</div>
                <div class="step-label">Đăng nhập</div>
            </div>
            <div class="step-item" id="step-capture">
                <div class="step-dot">2</div>
                <div class="step-label">Bắt config</div>
            </div>
            <div class="step-item" id="step-crawling">
                <div class="step-dot">3</div>
                <div class="step-label">Cào dữ liệu</div>
            </div>
            <div class="step-item" id="step-done">
                <div class="step-dot">✓</div>
                <div class="step-label">Hoàn thành</div>
            </div>
        </div>
    </div>

    <!-- Error -->
    <div class="error-card" id="errorCard"></div>

    <!-- Results -->
    <div class="results-wrapper" id="resultsWrapper">
        <div class="results-header">
            <h2 id="resultsTitle">Kết quả</h2>
            <div class="results-meta">
                <span class="badge">Tổng: <strong id="totalPosts">0</strong></span>
                <span class="badge badge-time" id="crawlDuration" style="display:none">
                    ⏱️ <strong id="crawlDurationText">0</strong>
                </span>
                <button class="btn-export" onclick="exportJson()">📥 Xuất JSON</button>
            </div>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('table')">📊 Bảng</button>
            <button class="tab-btn" onclick="switchTab('json')">📝 JSON</button>
        </div>

        <div class="tab-content active" id="tabTable">
            <div style="overflow-x: auto;">
                <table class="posts-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tác giả</th>
                            <th>Nội dung</th>
                            <th>Thời gian</th>
                            <th>Tương tác</th>
                            <th>Link</th>
                        </tr>
                    </thead>
                    <tbody id="postsBody"></tbody>
                </table>
            </div>
        </div>

        <div class="tab-content" id="tabJson">
            <div class="json-view">
                <pre id="jsonOutput"></pre>
            </div>
        </div>
    </div>
</div>

<script>
    let crawlData = null;
    let crawlStartTime = null;
    let elapsedInterval = null;

    function formatElapsed(seconds) {
        const m = Math.floor(seconds / 60);
        const s = Math.floor(seconds % 60);
        return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
    }

    function formatDuration(seconds) {
        if (seconds < 60) return `${Math.round(seconds)} giây`;
        const m = Math.floor(seconds / 60);
        const s = Math.round(seconds % 60);
        if (s === 0) return `${m} phút`;
        return `${m} phút ${s} giây`;
    }

    async function startCrawl() {
        const groupUrl = document.getElementById('groupUrl').value.trim();
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;
        const maxPosts = parseInt(document.getElementById('maxPosts').value) || 100;
        const clearCookies = document.getElementById('clearCookies').checked;

        if (!groupUrl) {
            showError('Vui lòng nhập Group URL');
            return;
        }

        const btn = document.getElementById('btnCrawl');
        btn.classList.add('loading');
        btn.disabled = true;

        hideError();
        hideResults();
        showProgress();
        startTimer();

        try {
            // Step 1: Start crawl session
            const startResp = await fetch('/Home/StartCrawl', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    groupUrl, dateFrom, dateTo, maxPosts, clearCookies
                })
            });

            if (!startResp.ok) {
                const errData = await startResp.json();
                showError(errData.error || 'Không thể khởi tạo crawl');
                resetButton();
                return;
            }

            const { sessionId } = await startResp.json();

            // Step 2: Listen for SSE progress
            const evtSource = new EventSource(
                `/Home/CrawlProgress?sessionId=${sessionId}`
            );

            evtSource.addEventListener('heartbeat', (e) => {
                const data = JSON.parse(e.data);
                document.getElementById('elapsedTime').textContent =
                    formatElapsed(data.elapsed);
            });

            evtSource.addEventListener('progress', (e) => {
                const data = JSON.parse(e.data);
                updateProgress(data);
            });

            evtSource.addEventListener('result', (e) => {
                evtSource.close();
                stopTimer();

                const data = JSON.parse(e.data);
                crawlData = data;

                if (!data.success) {
                    showError(data.error || 'Có lỗi xảy ra');
                    hideProgressPanel();
                    resetButton();
                    return;
                }

                // Mark done
                updateStepState('done');
                const bar = document.getElementById('progressBarFill');
                bar.classList.remove('indeterminate');
                bar.style.width = '100%';
                document.getElementById('progressBarText').textContent = '100%';
                document.getElementById('progressPhaseText').textContent = '✅ Hoàn thành!';
                document.getElementById('progressMessage').textContent =
                    `Đã cào ${data.total} bài viết`;

                const elapsed = crawlStartTime
                    ? (Date.now() - crawlStartTime) / 1000 : 0;

                setTimeout(() => {
                    hideProgressPanel();
                    showResults(data, elapsed);
                    resetButton();
                }, 1200);
            });

            evtSource.addEventListener('error', (e) => {
                if (evtSource.readyState === EventSource.CLOSED) return;
                evtSource.close();
                stopTimer();
                showError('Mất kết nối đến server');
                hideProgressPanel();
                resetButton();
            });

        } catch (err) {
            stopTimer();
            showError('Lỗi kết nối: ' + err.message);
            hideProgressPanel();
            resetButton();
        }
    }

    function updateProgress(data) {
        const { phase, message, current, total, page } = data;

        const phaseLabels = {
            'login': '🔐 Đăng nhập Facebook',
            'capture': '🎯 Bắt GraphQL config',
            'crawling': '📥 Đang cào bài viết',
            'done': '✅ Hoàn thành!'
        };
        document.getElementById('progressPhaseText').textContent =
            phaseLabels[phase] || message;

        updateStepState(phase);

        const bar = document.getElementById('progressBarFill');
        const barText = document.getElementById('progressBarText');

        if (phase === 'crawling' && total > 0) {
            bar.classList.remove('indeterminate');
            // Map crawling progress to 30%-95% range
            const rawPct = Math.round((current / total) * 100);
            const mappedPct = Math.min(30 + Math.round(rawPct * 0.65), 95);
            bar.style.width = mappedPct + '%';
            barText.textContent = `${rawPct}% — ${current}/${total} bài`;
        } else if (phase === 'done') {
            bar.classList.remove('indeterminate');
            bar.style.width = '100%';
            barText.textContent = '✅ 100% hoàn thành';
        } else if (phase === 'login') {
            bar.classList.remove('indeterminate');
            bar.style.width = '10%';
            barText.textContent = '~10% — Đang đăng nhập...';
        } else if (phase === 'capture') {
            bar.classList.remove('indeterminate');
            bar.style.width = '25%';
            barText.textContent = '~25% — Đang bắt config...';
        } else {
            bar.classList.add('indeterminate');
            barText.textContent = phaseLabels[phase] || message;
        }

        document.getElementById('progressMessage').textContent = message;
        if (phase === 'crawling' && total > 0) {
            document.getElementById('progressStats').textContent =
                `Trang ${page} • ${current}/${total} bài`;
        } else {
            document.getElementById('progressStats').textContent =
                message || '';
        }
    }

    function updateStepState(activePhase) {
        const steps = ['login', 'capture', 'crawling', 'done'];
        const activeIdx = steps.indexOf(activePhase);
        steps.forEach((step, i) => {
            const el = document.getElementById(`step-${step}`);
            el.classList.remove('active', 'done');
            if (i < activeIdx) el.classList.add('done');
            else if (i === activeIdx) el.classList.add('active');
        });
    }

    function showProgress() {
        document.getElementById('progressPanel').classList.add('visible');
        document.getElementById('progressBarFill').className = 'progress-bar-fill indeterminate';
        document.getElementById('progressBarFill').style.width = '0%';
        document.getElementById('progressBarText').textContent = 'Đang chuẩn bị...';
        document.getElementById('progressPhaseText').textContent = 'Đang khởi tạo...';
        document.getElementById('progressMessage').textContent = 'Đang kết nối...';
        document.getElementById('progressStats').textContent = '';
        document.getElementById('elapsedTime').textContent = '00:00';
        updateStepState('login');
    }

    function hideProgressPanel() {
        document.getElementById('progressPanel').classList.remove('visible');
    }

    function startTimer() {
        crawlStartTime = Date.now();
        elapsedInterval = setInterval(() => {
            const elapsed = (Date.now() - crawlStartTime) / 1000;
            document.getElementById('elapsedTime').textContent = formatElapsed(elapsed);
        }, 1000);
    }

    function stopTimer() {
        if (elapsedInterval) {
            clearInterval(elapsedInterval);
            elapsedInterval = null;
        }
    }

    function resetButton() {
        const btn = document.getElementById('btnCrawl');
        btn.classList.remove('loading');
        btn.disabled = false;
    }

    function showError(msg) {
        const card = document.getElementById('errorCard');
        card.textContent = '❌ ' + msg;
        card.classList.add('visible');
    }

    function hideError() {
        document.getElementById('errorCard').classList.remove('visible');
    }

    function hideResults() {
        document.getElementById('resultsWrapper').classList.remove('visible');
    }

    function showResults(data, elapsedSeconds) {
        document.getElementById('resultsWrapper').classList.add('visible');

        const title = data.group_name
            ? `${data.group_name} (${data.total} bài)`
            : `Kết quả: ${data.total} bài viết`;
        document.getElementById('resultsTitle').textContent = title;
        document.getElementById('totalPosts').textContent = data.total;

        // Show duration badge
        if (elapsedSeconds > 0) {
            const durationBadge = document.getElementById('crawlDuration');
            durationBadge.style.display = 'inline-block';
            document.getElementById('crawlDurationText').textContent =
                formatDuration(elapsedSeconds);
        }

        // Build table
        const tbody = document.getElementById('postsBody');
        tbody.innerHTML = '';

        (data.posts || []).forEach((post, i) => {
            const tr = document.createElement('tr');
            const content = post.content || '[Không có nội dung]';
            const shortContent = content.length > 150
                ? content.substring(0, 150) + '...'
                : content;

            tr.innerHTML = `
                <td>${i + 1}</td>
                <td class="col-author">${escHtml(post.author_name || 'N/A')}</td>
                <td class="col-content" title="${escHtml(content)}">${escHtml(shortContent)}</td>
                <td class="col-time">${escHtml(post.created_time_formatted || '')}</td>
                <td class="col-stats">
                    <span class="stat-badge stat-reactions">❤️ ${post.reaction_count || 0}</span>
                    <span class="stat-badge stat-comments">💬 ${post.comment_count || 0}</span>
                    <span class="stat-badge stat-shares">🔄 ${post.share_count || 0}</span>
                </td>
                <td>
                    ${post.post_url
                    ? `<a href="${escHtml(post.post_url)}" target="_blank" class="post-link">Xem ↗</a>`
                    : '-'}
                </td>
            `;
            tbody.appendChild(tr);
        });

        // JSON output
        document.getElementById('jsonOutput').textContent =
            JSON.stringify(data, null, 2);
    }

    function switchTab(tab) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

        if (tab === 'table') {
            document.querySelector('.tab-btn:nth-child(1)').classList.add('active');
            document.getElementById('tabTable').classList.add('active');
        } else {
            document.querySelector('.tab-btn:nth-child(2)').classList.add('active');
            document.getElementById('tabJson').classList.add('active');
        }
    }

    function exportJson() {
        if (!crawlData) return;
        const blob = new Blob(
            [JSON.stringify(crawlData, null, 2)],
            { type: 'application/json' }
        );
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `group_posts_${crawlData.group_id || 'export'}_${Date.now()}.json`;
        a.click();
        URL.revokeObjectURL(url);
    }

    function escHtml(str) {
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
    }
</script>
